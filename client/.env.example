# Client (Vite) environment variables
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
# Read at BUILD time, not runtime — changing these requires a rebuild.

# Google Maps API key (existing — used for address autocomplete)
VITE_GOOGLE_MAPS_API_KEY=

# Google Sign-In OAuth Client ID
# Same value as GOOGLE_CLIENT_ID on the server.
# Not a secret — appears in the public JS bundle.
# If unset, the Google sign-in button is hidden and email/password still works.
VITE_GOOGLE_CLIENT_ID=
