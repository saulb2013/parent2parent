DATABASE_URL=postgresql://user:password@localhost:5432/parent2parent
JWT_SECRET=change-this-to-a-random-secret-string

# Yoco payment gateway (https://portal.yoco.com → Developers → Keys)
YOCO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Returned by Yoco once when registering the webhook subscription
YOCO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL of the deployed client (used for payment return redirect)
CLIENT_URL=http://localhost:5173

# Operator email for operational alerts (shipment creation failures, etc).
# Optional — defaults to saul.bloch13@gmail.com if unset.
ADMIN_ALERT_EMAIL=you@example.com

# Google Sign-In OAuth Client ID
# (Google Cloud Console → APIs & Services → Credentials)
# Not a secret — also exposed in the client bundle.
# If unset, the Google sign-in button is hidden and email/password still works.
GOOGLE_CLIENT_ID=
