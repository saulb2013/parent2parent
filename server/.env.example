DATABASE_URL=postgresql://user:password@localhost:5432/parent2parent
JWT_SECRET=change-this-to-a-random-secret-string

# Stitch Express payment gateway (Settings → API Keys in dashboard)
STITCH_CLIENT_ID=test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
STITCH_CLIENT_SECRET=your-stitch-client-secret
# Returned by Stitch when registering the webhook (POST /api/v1/webhook)
STITCH_WEBHOOK_SECRET=your-stitch-webhook-secret

# Public URL of the deployed client (used for payment return redirect)
CLIENT_URL=http://localhost:5173
